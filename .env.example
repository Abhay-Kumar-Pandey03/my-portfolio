# Copy this file to .env and fill in your real values.
# .env is git-ignored — never commit your real keys.

# EmailJS — https://dashboard.emailjs.com
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Google reCAPTCHA v2 (checkbox) — https://www.google.com/recaptcha/admin
# Register a v2 "I'm not a robot" checkbox site here. Use the SAME site key + secret key
# pair in EmailJS's dashboard (Account > Security > reCAPTCHA) so EmailJS can verify
# submissions server-side before sending.
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v2_site_key
